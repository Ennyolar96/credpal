  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateUser": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email"
          },
          "fullname": {
            "type": "string",
            "description": "User fullname"
          },
          "refercode": {
            "type": "string",
            "description": "User refercode"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "fullname",
          "password"
        ]
      },
      "UserEntity": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "fullname": {
            "type": "string"
          },
          "role": {
            "enum": [
              "user",
              "admin"
            ],
            "type": "string"
          },
          "verified": {
            "type": "boolean"
          },
          "expiredAt": {
            "format": "date-time",
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "refercode": {
            "type": "string"
          },
          "referralCode": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "email",
          "fullname",
          "role",
          "verified",
          "referralCode",
          "password",
          "id",
          "createdAt",
          "updatedAt"
        ]
      },
      "VerifyUser": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email"
          },
          "token": {
            "type": "string",
            "description": "User token"
          }
        },
        "required": [
          "email",
          "token"
        ]
      },
      "SignInUser": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "WalletEntity": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "user": {
            "type": "object"
          },
          "currency": {
            "type": "string",
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ]
          },
          "balance": {
            "type": "number"
          },
          "ledgerBalance": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "INACTIVE",
              "PENDING",
              "BLOCKED",
              "SUSPENDED"
            ]
          },
          "id": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "userId",
          "currency",
          "balance",
          "ledgerBalance",
          "status",
          "id",
          "createdAt",
          "updatedAt"
        ]
      },
      "FundWallet": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 1
          },
          "currency": {
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ],
            "type": "string"
          },
          "idempotency": {
            "type": "string",
            "format": "uuid"
          },
          "narration": {
            "type": "string"
          }
        },
        "required": [
          "amount",
          "currency",
          "idempotency"
        ]
      },
      "Convert": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "string",
            "minimum": 1
          },
          "from": {
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ],
            "type": "string"
          },
          "to": {
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ],
            "type": "string"
          },
          "idempotency": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "amount",
          "from",
          "to",
          "idempotency"
        ]
      },
      "Trade": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "string",
            "minimum": 1
          },
          "from": {
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ],
            "type": "string"
          },
          "to": {
            "enum": [
              "NGN",
              "USD",
              "EUR",
              "GBP"
            ],
            "type": "string"
          },
          "idempotency": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "amount",
          "from",
          "to",
          "idempotency"
        ]
      }
    }
  }
